---
layout: 
---

[
{% assign first_entry = true %}
{% for post in site.posts %}
  {% if post.unlisted != true %}
  {% assign entry_title = post.title | default: post.excerpt | strip_html | strip %}
  {% assign entry_desc = post.subtitle | default: post.excerpt | default: post.title | strip_html | strip %}
  {% assign entry_content = post.content | strip_html | strip_newlines | strip | truncatewords: 80 %}
  {% assign entry_category = post.tags | join: ', ' %}
  {% if entry_category == "" %}
    {% assign entry_category = "post" %}
  {% endif %}
  {% unless first_entry %},{% endunless %}
  {% assign first_entry = false %}
  {
    "title": {{ entry_title | jsonify }},
    "desc": {{ entry_desc | jsonify }},
    "content": {{ entry_content | jsonify }},
    "author": {{ post.author | default: site.author.name | default: site.author | jsonify }},
    "category": {{ entry_category | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%B %e, %Y" | default: "January 1, 1970" | jsonify }},
    "timestamp": {{ post.date | date: "%s" | default: "0" | jsonify }}
  }
  {% endif %}
{% endfor %}
{% for page in site.html_pages %}
  {% if page.title != "{title}" and page.title != "404 - Page not found" %}
    {% assign entry_title = page.title | default: page.excerpt | strip_html | strip %}
    {% assign entry_desc = page.subtitle | default: page.excerpt | default: page.title | strip_html | strip %}
    {% assign entry_content = page.content | strip_html | strip_newlines | strip | truncatewords: 80 %}
    {% assign entry_category = page.tags | join: ', ' %}
    {% if entry_category == "" %}
      {% assign entry_category = "page" %}
    {% endif %}
    {% unless first_entry %},{% endunless %}
    {% assign first_entry = false %}
    {
      "title": {{ entry_title | jsonify }},
      "desc": {{ entry_desc | jsonify }},
      "content": {{ entry_content | jsonify }},
      "author": {{ page.author | default: site.author.name | default: site.author | jsonify }},
      "category": {{ entry_category | jsonify }},
      "url": {{ page.url | relative_url | jsonify }},
      "date": {{ page.date | date: "%B %e, %Y" | default: "January 1, 1970" | jsonify }},
      "timestamp": {{ page.date | date: "%s" | default: "0" | jsonify }}
    }
  {% endif %}
{% endfor %}
]
